<%= bootstrap_form_with(model: photo, id: dom_id(photo, :edit_form)) do |form| %>
  <% if photo.errors.any? %>
    <div style="color: red">
      <h2><%= t ".errors", count: photo.errors.count %></h2>

      <ul>
        <% photo.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if photo.persisted? %>
      <%= image_tag photo.photo, class: %w[img-fluid d-block], alt: photo.alt %>
  <% else %>
    <%= form.hidden_field :photoable_id %>
    <%= form.hidden_field :photoable_type %>

    <div data-controller="cropper">
      <%= form.file_field :photo, data: { "cropper-target": "imageInput", action: "change->cropper#setup" } %>
      <%= form.hidden_field :photo_crop_data, data: { "cropper-target": "dataInput" } %>

      <div style="max-height: 500px; min-height: 500px" class="mb-3">
        <img data-cropper-target="croppableImage">
      </div>

      <%= render "shared/cropper_buttons" %>
    </div>
  <% end %>

  <%= form.text_field :alt %>

  <div>
    <%= form.submit %>
  </div>
<% end %>

<% if photo.persisted? %>
  <div class="mt-3">
    <%= bootstrap_form_with(
          model: photo,
          id: dom_id(photo, :delete_form),
          method: :delete,
          data: { turbo_confirm: t(".delete_confirm") },
        ) do |f| %>
      <%= f.submit t(".delete"), class: "btn btn-danger" %>
    <% end %>
  </div>
<% end %>
