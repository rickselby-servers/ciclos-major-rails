<h1><%= t "galleries.index.title" %></h1>

<h2><%= @gallery.name %></h2>

<% if admin_signed_in? %>
  <div>
    <%= link_to edit_gallery_path(@gallery), class: %i[btn btn-secondary] do %>
      <%= fa_icon "pencil" %>
      <%= t ".edit" %>
    <% end %>
    <%= link_to new_photo_path(target: @gallery.to_global_id), data: { turbo_frame: "modal" }, class: %i[btn btn-primary] do %>
      <%= fa_icon "plus" %>
      <%= t "photos.add" %>
    <% end %>
  </div>
<% end %>

<div class="row row-cols-2 row-cols-md-3">
  <% @gallery.photos.ordered.each do |photo| %>
    <div class="col mb-3 align-items-center d-flex flex-column">
      <%= image_tag photo.photo, class: %w[img-fluid d-block] %>

      <% if admin_signed_in? %>
        <%= link_to edit_photo_path(photo), data: { turbo_frame: "modal" }, class: %i[btn btn-primary d-flex] do %>
          <%= fa_icon "pencil" %>
          <%= t "photos.edit_button" %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
